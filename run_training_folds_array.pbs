#!/bin/bash
#PBS -N lob_train_fold
#PBS -l walltime=15:00:00
#PBS -l select=1:ncpus=10:mem=48gb:ngpus=1
#PBS -J 1-6%3

set -euo pipefail
SCRIPT_START_EPOCH="$(date +%s)"

PROJECT_DIR="$HOME/Dual-Attention-for-LOB-Price-Trend-Prediction"
WORK_DIR="$TMPDIR/Dual-Attention-for-LOB-Price-Trend-Prediction"
FOLDS_FILE="$PROJECT_DIR/configs/folds.txt"

ARRAY_JOB_ID="${PBS_JOBID%%[*}"
RUN_STEM="${TRAINING_RUN_STEM:-training_${ARRAY_JOB_ID}}"

if [ ! -f "$FOLDS_FILE" ]; then
  echo "Fold list not found: $FOLDS_FILE" >&2
  exit 1
fi

FOLD_ID="$(
  awk -v fold_index="$PBS_ARRAY_INDEX" '
    NF && $1 !~ /^#/ {
      count++
      if (count == fold_index) {
        print $1
        exit
      }
    }
  ' "$FOLDS_FILE"
)"

if [ -z "$FOLD_ID" ]; then
  echo "No fold id found for PBS_ARRAY_INDEX=$PBS_ARRAY_INDEX" >&2
  exit 1
fi

RUN_OUTPUT_DIR="$HOME/run_outputs/$RUN_STEM/$FOLD_ID"
PROJECT_JOB_LOG_DIR="$PROJECT_DIR/logs/$RUN_STEM/$FOLD_ID"
LOG_FILE="run_logs.txt"
LOG_PATH="$PROJECT_JOB_LOG_DIR/$LOG_FILE"
LOG_FIFO="$TMPDIR/run_log_fifo.$$"
RUN_MARKER="$TMPDIR/run_output_marker.$$"

format_duration() {
  total_seconds="$1"
  hours=$((total_seconds / 3600))
  minutes=$(((total_seconds % 3600) / 60))
  seconds=$((total_seconds % 60))
  if [ "$hours" -gt 0 ]; then
    printf "%dh %02dm %02ds" "$hours" "$minutes" "$seconds"
  elif [ "$minutes" -gt 0 ]; then
    printf "%dm %02ds" "$minutes" "$seconds"
  else
    printf "%ds" "$seconds"
  fi
}

same_file() {
  left_path="$1"
  right_path="$2"

  if [ ! -e "$left_path" ] || [ ! -e "$right_path" ]; then
    return 1
  fi

  left_real="$(readlink -f "$left_path" 2>/dev/null || true)"
  right_real="$(readlink -f "$right_path" 2>/dev/null || true)"

  [ -n "$left_real" ] && [ "$left_real" = "$right_real" ]
}

mkdir -p "$PROJECT_JOB_LOG_DIR"
: > "$LOG_PATH"
mkfifo "$LOG_FIFO"
tee -a "$LOG_PATH" < "$LOG_FIFO" &
TEE_PID=$!
exec 3>&1 4>&2
exec > "$LOG_FIFO" 2>&1
rm -f "$LOG_FIFO"

copy_file_to_outputs() {
  source_path="$1"
  relative_path="${source_path#$WORK_DIR/}"
  target_path="$RUN_OUTPUT_DIR/$relative_path"
  mkdir -p "$(dirname "$target_path")"
  cp -p "$source_path" "$target_path"
}

copy_file_to_project() {
  source_path="$1"
  relative_path="${source_path#$WORK_DIR/}"
  target_path="$PROJECT_DIR/$relative_path"
  if same_file "$source_path" "$target_path"; then
    return 0
  fi
  mkdir -p "$(dirname "$target_path")"
  cp -p "$source_path" "$target_path"
}

copy_generated_file() {
  source_path="$1"
  copy_file_to_project "$source_path"
  copy_file_to_outputs "$source_path"
}

copy_newer_files_from_dir() {
  output_dir="$1"
  if [ -d "$output_dir" ]; then
    while IFS= read -r -d '' output_file; do
      copy_generated_file "$output_file"
    done < <(find -L "$output_dir" -type f -newer "$RUN_MARKER" -print0)
  fi
}

copy_run_outputs() {
  mkdir -p "$RUN_OUTPUT_DIR"
  mkdir -p "$PROJECT_JOB_LOG_DIR"

  if [ -f "$LOG_PATH" ]; then
    cp "$LOG_PATH" "$RUN_OUTPUT_DIR/$LOG_FILE"
  fi

  if [ -f "$RUN_MARKER" ] && [ -d "$WORK_DIR" ]; then
    for output_dir in "$WORK_DIR/logs/$RUN_STEM/$FOLD_ID" "$WORK_DIR/results/$RUN_STEM/$FOLD_ID"; do
      copy_newer_files_from_dir "$output_dir"
    done

    summary_file="$WORK_DIR/logs/$RUN_STEM/summary_$FOLD_ID.yaml"
    if [ -f "$summary_file" ] && [ "$summary_file" -newer "$RUN_MARKER" ]; then
      copy_generated_file "$summary_file"
    fi
  fi
}

finish() {
  status=$?
  set +e

  echo
  echo "===== FINISHING TRAINING FOLD JOB ====="
  echo "Exit status=$status"
  echo "RUN_STEM=$RUN_STEM"
  echo "FOLD_ID=$FOLD_ID"
  echo "TMPDIR=$TMPDIR"
  echo "WORK_DIR=$WORK_DIR"
  echo "RUN_OUTPUT_DIR=$RUN_OUTPUT_DIR"
  echo "PROJECT_JOB_LOG_DIR=$PROJECT_JOB_LOG_DIR"

  end_epoch="$(date +%s)"
  elapsed=$((end_epoch - SCRIPT_START_EPOCH))
  echo "Total runtime=$(format_duration "$elapsed") (${elapsed}s)"

  exec 1>&3 2>&4
  wait "$TEE_PID" || true

  copy_run_outputs
  exit "$status"
}

terminate() {
  signal="$1"
  status="$2"
  echo
  echo "===== RECEIVED $signal ====="
  exit "$status"
}

trap 'terminate TERM 143' TERM
trap 'terminate INT 130' INT
trap finish EXIT

echo "===== TRAINING ARRAY TASK START ====="
date
echo "PBS_JOBID=$PBS_JOBID"
echo "ARRAY_JOB_ID=$ARRAY_JOB_ID"
echo "PBS_ARRAY_INDEX=$PBS_ARRAY_INDEX"
echo "RUN_STEM=$RUN_STEM"
echo "FOLD_ID=$FOLD_ID"
echo "HOSTNAME=$(hostname)"
echo "TMPDIR=$TMPDIR"

ml purge

set +u
eval "$($HOME/miniforge3/bin/conda shell.bash hook)"
conda activate transformer
set -u

# Avoid accidental CPU oversubscription from native libraries.
export OMP_NUM_THREADS=1
export MKL_NUM_THREADS=1
export OPENBLAS_NUM_THREADS=1
export NUMEXPR_NUM_THREADS=1
export PYTHONUNBUFFERED=1

echo
echo "===== GPU INFO ====="
which nvidia-smi || true
nvidia-smi || true

echo
echo "===== PYTHON INFO ====="
which python
python --version
python -c "import sys; print(sys.executable); print(sys.version)"

echo
echo "===== COPYING CODE TO TMPDIR ====="
mkdir -p "$WORK_DIR"
rsync -a \
  --exclude=".git" \
  --exclude="data" \
  --exclude="logs" \
  --exclude="results" \
  "$PROJECT_DIR/" "$WORK_DIR/"

echo
echo "===== LINKING PERSISTENT OUTPUT DIRECTORIES ====="
mkdir -p "$PROJECT_DIR/logs" "$PROJECT_DIR/results"
rm -rf "${WORK_DIR:?}/logs" "${WORK_DIR:?}/results"
ln -s "$PROJECT_DIR/logs" "$WORK_DIR/logs"
ln -s "$PROJECT_DIR/results" "$WORK_DIR/results"

echo
echo "===== STAGING SEQUENCE DATA FOR $FOLD_ID ====="
mkdir -p "$WORK_DIR/data/sequences/$FOLD_ID"
rsync -a "$PROJECT_DIR/data/sequences/$FOLD_ID/" \
  "$WORK_DIR/data/sequences/$FOLD_ID/"

cd "$WORK_DIR"
touch "$RUN_MARKER"

echo
echo "===== RUNNING TRAINING FOR $FOLD_ID ====="
PYTHONPATH="$WORK_DIR/src:${PYTHONPATH:-}" \
python scripts/run_training.py \
  --fold-id "$FOLD_ID" \
  --run-stem "$RUN_STEM"

echo
echo "===== TRAINING FOLD COMPLETED OK ====="
date